# 本地配置示例：复制为 application-local.yml 并填入真实值，该文件已被 .gitignore 忽略
# 需在启动参数或配置中激活 spring profile：local（例如 spring.profiles.active=api,local）后本文件才会生效
#
# 浏览器 DevTools 重放「提交订单」且沿用同一 submitToken 时，可临时关闭 Token 校验：
# order:
#   submit-token-verify: false

# 阿里云短信密钥（或通过环境变量 ALIYUN_SMS_ACCESS_KEY_ID / ALIYUN_SMS_ACCESS_KEY_SECRET 注入）
aliyun:
  sms:
    access-key-id: your-access-key-id
    access-key-secret: your-access-key-secret
    sign-name: 你的签名名称
    template-code: SMS_xxxxxxxxx
